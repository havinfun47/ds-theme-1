      "blocks": [
        { "type": "item", "settings": { "text": "Targets parasites, larvae, and eggs at the same time" } },
        { "type": "item", "settings": { "text": "Helps reduce bloating, gas, and digestive discomfort" } },
        { "type": "item", "settings": { "text": "Supports healthy, regular bowel movements" } },
        { "type": "item", "settings": { "text": "Fights fatigue and restores daily energy" } },
        { "type": "item", "settings": { "text": "Clears brain fog and supports mental clarity" } },
        { "type": "item", "settings": { "text": "Curbs sugar and carb cravings" } },
        { "type": "item", "settings": { "text": "Promotes clearer, healthier-looking skin" } },
        { "type": "item", "settings": { "text": "Supports better, more restful sleep" } },
        { "type": "item", "settings": { "text": "Replenishes nutrients with fulvic acid trace minerals" } },
        { "type": "item", "settings": { "text": "Helps repair and strengthen the gut lining" } },
        { "type": "item", "settings": { "text": "Improves nutrient absorption after the cleanse" } },
        { "type": "item", "settings": { "text": "Sublingual delivery for faster absorption than capsules" } },
        { "type": "item", "settings": { "text": "Clean, non-GMO herbs — no fillers or synthetics" } }
