{%- liquid
  assign p = product
  assign has_product = false
  if p != blank and p.id != blank
    assign has_product = true
  endif

  assign current_variant = p.selected_or_first_available_variant

  # Build gallery image list: real product images, else fallback theme assets
  assign fallback_images = 'gc-hero.jpg,gc-img-1.png,gc-img-2.png,gc-img-3.png,gc-img-4.png' | split: ','
-%}

<div
  class="gc-section gc-hero"
  style="
    --gc-bg: {{ section.settings.background_color }};
    --gc-text: {{ section.settings.text_color }};
    --gc-accent: {{ section.settings.accent_color }};
    --gc-sale: {{ section.settings.sale_color }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  {%- if section.settings.promo_text != blank -%}
    <div class="gc-hero__promo">{{ section.settings.promo_text }}</div>
  {%- endif -%}

  <div class="gc-container gc-hero__grid">
    {%- comment -%} ---------- GALLERY ---------- {%- endcomment -%}
    <div class="gc-hero__gallery" data-gc-gallery>
      <div class="gc-hero__main">
        {%- if has_product and p.images.size > 0 -%}
          {%- assign first_img = p.images | first -%}
          <img
            data-gc-main
            src="{{ first_img | image_url: width: 900 }}"
            alt="{{ p.title | escape }}"
            width="900"
            height="900"
            loading="eager"
          >
        {%- else -%}
          <img
            data-gc-main
            src="{{ 'gc-hero.jpg' | asset_url }}"
            alt="{{ section.settings.fallback_title | escape }}"
            width="900"
            height="900"
            loading="eager"
          >
        {%- endif -%}
      </div>

      <div class="gc-hero__thumbs">
        {%- if has_product and p.images.size > 0 -%}
          {%- for img in p.images limit: 6 -%}
            <button
              type="button"
              class="gc-hero__thumb{% if forloop.first %} is-active{% endif %}"
              data-gc-thumb
              data-gc-full="{{ img | image_url: width: 900 }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ img | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- for asset in fallback_images -%}
            <button
              type="button"
              class="gc-hero__thumb{% if forloop.first %} is-active{% endif %}"
              data-gc-thumb
              data-gc-full="{{ asset | asset_url }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ asset | asset_url }}" alt="" width="80" height="80" loading="lazy">
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ---------- BUY BOX ---------- {%- endcomment -%}
    <div class="gc-hero__info">
      {%- if section.settings.vendor != blank -%}
        <div class="gc-hero__vendor">{{ section.settings.vendor }}</div>
      {%- endif -%}

      <h1 class="gc-hero__title">
        {%- if has_product -%}{{ p.title }}{%- else -%}{{ section.settings.fallback_title }}{%- endif -%}
      </h1>

      <div class="gc-hero__rating">
        <span class="gc-hero__stars" aria-hidden="true">★★★★★</span>
        <span class="gc-hero__rating-text">{{ section.settings.rating_score }} · {{ section.settings.rating_count }} reviews</span>
      </div>

      {%- comment -%} ---------- PRICE ---------- {%- endcomment -%}
      <div class="gc-hero__price">
        {%- if has_product -%}
          {%- assign price_now = current_variant.price | default: p.price -%}
          {%- assign price_was = current_variant.compare_at_price -%}
          {%- if price_was > price_now -%}
            <span class="gc-hero__price-now gc-hero__price-now--sale">{{ price_now | money }}</span>
            <s class="gc-hero__price-was">{{ price_was | money }}</s>
          {%- else -%}
            <span class="gc-hero__price-now">{{ price_now | money }}</span>
            {%- if section.settings.fallback_compare_at != blank -%}
              <s class="gc-hero__price-was">{{ section.settings.fallback_compare_at }}</s>
            {%- endif -%}
          {%- endif -%}
        {%- else -%}
          <span class="gc-hero__price-now{% if section.settings.fallback_compare_at != blank %} gc-hero__price-now--sale{% endif %}">{{ section.settings.fallback_price }}</span>
          {%- if section.settings.fallback_compare_at != blank -%}
            <s class="gc-hero__price-was">{{ section.settings.fallback_compare_at }}</s>
          {%- endif -%}
        {%- endif -%}
        {%- if section.settings.sale_badge != blank -%}
          <span class="gc-hero__sale-badge">{{ section.settings.sale_badge }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.short_description != blank -%}
        <div class="gc-hero__desc">{{ section.settings.short_description }}</div>
      {%- endif -%}

      {%- comment -%} ---------- STOCK BAR ---------- {%- endcomment -%}
      {%- if section.settings.show_stock_bar -%}
        <div class="gc-hero__stock">
          <div class="gc-hero__stock-track">
            <div class="gc-hero__stock-fill" style="width: {{ section.settings.stock_percent }}%;"></div>
          </div>
          <div class="gc-hero__stock-label">{{ section.settings.stock_percent }}% Sold — selling fast</div>
        </div>
      {%- endif -%}

      {%- comment -%} ---------- PURCHASE OPTIONS ---------- {%- endcomment -%}
      {%- if section.settings.show_purchase_options -%}
        <div class="gc-hero__options" role="radiogroup" aria-label="Purchase options">
          <label class="gc-hero__option is-selected">
            <input type="radio" name="gc-purchase" value="onetime" checked>
            <span class="gc-hero__option-main">
              <span class="gc-hero__option-title">One-Time Purchase</span>
              <span class="gc-hero__option-sub">Ships once. No commitment.</span>
            </span>
          </label>
          <label class="gc-hero__option">
            <input type="radio" name="gc-purchase" value="subscribe">
            <span class="gc-hero__option-main">
              <span class="gc-hero__option-title">Subscribe &amp; Save 10%</span>
              <span class="gc-hero__option-sub">Skip, pause, or cancel anytime.</span>
            </span>
            <span class="gc-hero__option-tag">Best Value</span>
          </label>
        </div>
      {%- endif -%}

      {%- comment -%} ---------- ADD TO CART ---------- {%- endcomment -%}
      {%- if has_product -%}
        {%- form 'product', p, class: 'gc-hero__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <div class="gc-hero__qty">
            <button type="button" class="gc-hero__qty-btn" data-gc-minus aria-label="Decrease quantity">−</button>
            <input type="number" name="quantity" value="1" min="1" data-gc-qty aria-label="Quantity">
            <button type="button" class="gc-hero__qty-btn" data-gc-plus aria-label="Increase quantity">+</button>
          </div>
          <button
            type="submit"
            name="add"
            class="gc-hero__atc"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}{{ section.settings.button_label }}{%- else -%}Sold Out{%- endif -%}
          </button>
        {%- endform -%}
      {%- else -%}
        <div class="gc-hero__form">
          <div class="gc-hero__qty">
            <button type="button" class="gc-hero__qty-btn" data-gc-minus aria-label="Decrease quantity">−</button>
            <input type="number" value="1" min="1" data-gc-qty aria-label="Quantity">
            <button type="button" class="gc-hero__qty-btn" data-gc-plus aria-label="Increase quantity">+</button>
          </div>
          <button type="button" class="gc-hero__atc">{{ section.settings.button_label }}</button>
        </div>
      {%- endif -%}

      {%- comment -%} ---------- TRUST BADGES ---------- {%- endcomment -%}
      <ul class="gc-hero__trust">
        {%- for block in section.blocks -%}
          <li class="gc-hero__trust-item" {{ block.shopify_attributes }}>
            <span class="gc-hero__trust-icon">{{ block.settings.icon }}</span>
            <span>{{ block.settings.label }}</span>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.guarantee_text != blank -%}
        <p class="gc-hero__guarantee">{{ section.settings.guarantee_text }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('#shopify-section-{{ section.id }}');
    if (!root) return;

    // Thumbnail → main image swap
    var main = root.querySelector('[data-gc-main]');
    root.querySelectorAll('[data-gc-thumb]').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var full = thumb.getAttribute('data-gc-full');
        if (full && main) main.src = full;
        root.querySelectorAll('[data-gc-thumb]').forEach(function (t) { t.classList.remove('is-active'); });
        thumb.classList.add('is-active');
      });
    });

    // Quantity stepper
    var qty = root.querySelector('[data-gc-qty]');
    var minus = root.querySelector('[data-gc-minus]');
    var plus = root.querySelector('[data-gc-plus]');
    if (qty) {
      if (minus) minus.addEventListener('click', function () {
        var v = parseInt(qty.value, 10) || 1; if (v > 1) qty.value = v - 1;
      });
      if (plus) plus.addEventListener('click', function () {
        var v = parseInt(qty.value, 10) || 1; qty.value = v + 1;
      });
    }

    // Purchase option selection (visual)
    root.querySelectorAll('.gc-hero__option input').forEach(function (input) {
      input.addEventListener('change', function () {
        root.querySelectorAll('.gc-hero__option').forEach(function (o) { o.classList.remove('is-selected'); });
        input.closest('.gc-hero__option').classList.add('is-selected');
      });
    });
  })();
</script>

{% stylesheet %}
  .gc-hero { background: var(--gc-bg); color: var(--gc-text); }
  .gc-hero__promo {
    text-align: center;
    background: var(--gc-accent);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 10px 16px;
    margin-bottom: 28px;
    border-radius: 8px;
    text-transform: uppercase;
    font-size: 0.9rem;
  }
  .gc-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
    align-items: flex-start;
  }
  /* Gallery */
  .gc-hero__main {
    border-radius: 18px;
    overflow: hidden;
    background: color-mix(in srgb, var(--gc-accent) 8%, #fff);
  }
  .gc-hero__main img { width: 100%; height: auto; display: block; aspect-ratio: 1 / 1; object-fit: cover; }
  .gc-hero__thumbs {
    display: flex;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .gc-hero__thumb {
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    background: none;
  }
  .gc-hero__thumb.is-active { border-color: var(--gc-accent); }
  .gc-hero__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  /* Info */
  .gc-hero__vendor { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.78rem; opacity: 0.6; font-weight: 600; }
  .gc-hero__title { font-size: clamp(1.5rem, 3vw, 2.1rem); line-height: 1.2; margin: 8px 0 12px; }
  .gc-hero__rating { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .gc-hero__stars { color: #f5a623; letter-spacing: 2px; }
  .gc-hero__rating-text { font-size: 0.9rem; opacity: 0.75; }
  .gc-hero__price { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
  .gc-hero__price-now { font-size: 1.8rem; font-weight: 800; }
  .gc-hero__price-now--sale { color: var(--gc-sale); }
  .gc-hero__price-was { font-size: 1.2rem; opacity: 0.5; }
  .gc-hero__sale-badge {
    background: var(--gc-sale); color: #fff; font-size: 0.75rem; font-weight: 700;
    padding: 4px 10px; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .gc-hero__desc { line-height: 1.6; opacity: 0.9; margin-bottom: 20px; }
  .gc-hero__desc p { margin: 0 0 0.6em; }
  /* Stock bar */
  .gc-hero__stock { margin-bottom: 22px; }
  .gc-hero__stock-track { height: 10px; border-radius: 999px; background: color-mix(in srgb, var(--gc-accent) 18%, #e5e5e5); overflow: hidden; }
  .gc-hero__stock-fill { height: 100%; background: var(--gc-sale); border-radius: 999px; }
  .gc-hero__stock-label { font-size: 0.85rem; font-weight: 600; margin-top: 6px; color: var(--gc-sale); }
  /* Purchase options */
  .gc-hero__options { display: grid; gap: 10px; margin-bottom: 20px; }
  .gc-hero__option {
    display: flex; align-items: center; gap: 12px; padding: 14px 16px;
    border: 2px solid color-mix(in srgb, var(--gc-text) 14%, transparent);
    border-radius: 12px; cursor: pointer; position: relative;
  }
  .gc-hero__option.is-selected { border-color: var(--gc-accent); background: color-mix(in srgb, var(--gc-accent) 8%, transparent); }
  .gc-hero__option input { accent-color: var(--gc-accent); width: 18px; height: 18px; }
  .gc-hero__option-main { display: flex; flex-direction: column; }
  .gc-hero__option-title { font-weight: 700; }
  .gc-hero__option-sub { font-size: 0.85rem; opacity: 0.7; }
  .gc-hero__option-tag {
    margin-left: auto; background: var(--gc-accent); color: #fff; font-size: 0.7rem; font-weight: 700;
    padding: 3px 9px; border-radius: 999px; text-transform: uppercase;
  }
  /* Form */
  .gc-hero__form { display: flex; gap: 12px; align-items: stretch; margin-bottom: 18px; }
  .gc-hero__qty {
    display: flex; align-items: center; border: 2px solid color-mix(in srgb, var(--gc-text) 16%, transparent);
    border-radius: 12px; overflow: hidden;
  }
  .gc-hero__qty-btn { width: 42px; border: none; background: none; font-size: 1.3rem; cursor: pointer; color: inherit; }
  .gc-hero__qty input { width: 48px; text-align: center; border: none; background: none; font-size: 1rem; color: inherit; -moz-appearance: textfield; }
  .gc-hero__qty input::-webkit-outer-spin-button, .gc-hero__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .gc-hero__atc {
    flex: 1; border: none; border-radius: 12px; background: var(--gc-accent); color: #fff;
    font-size: 1.05rem; font-weight: 700; cursor: pointer; padding: 16px 24px; transition: filter 0.15s ease;
  }
  .gc-hero__atc:hover { filter: brightness(0.93); }
  .gc-hero__atc:disabled { opacity: 0.5; cursor: not-allowed; }
  /* Trust */
  .gc-hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 10px 22px; padding: 0; margin: 0 0 14px; }
  .gc-hero__trust-item { display: flex; align-items: center; gap: 7px; font-size: 0.88rem; font-weight: 600; }
  .gc-hero__trust-icon { font-size: 1.1rem; }
  .gc-hero__guarantee { font-size: 0.9rem; opacity: 0.75; margin: 0; }
  @media screen and (max-width: 749px) {
    .gc-hero__grid { grid-template-columns: 1fr; gap: 28px; }
    .gc-hero__form { flex-wrap: wrap; }
    .gc-hero__atc { flex: 1 0 100%; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "GC Product Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo bar text",
      "default": "🔥 30% OFF + FREE SHIPPING — Early Summer Sale"
    },
    {
      "type": "text",
      "id": "vendor",
      "label": "Vendor / eyebrow",
      "default": "Wild Harvest®"
    },
    {
      "type": "header",
      "content": "Fallback content (no product assigned)"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "Wild Harvest® GutCleanse 2-Step Parasite Cleanse Kit"
    },
    {
      "type": "text",
      "id": "fallback_price",
      "label": "Fallback price",
      "default": "$79.99"
    },
    {
      "type": "text",
      "id": "fallback_compare_at",
      "label": "Fallback compare-at price (leave blank for none)",
      "default": "$114.99"
    },
    {
      "type": "header",
      "content": "Rating & badges"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Review count",
      "default": "7,979"
    },
    {
      "type": "text",
      "id": "sale_badge",
      "label": "Sale badge (leave blank for none)",
      "default": "Save 30%"
    },
    {
      "type": "richtext",
      "id": "short_description",
      "label": "Short description",
      "default": "<p>A complete 2-step herbal cleanse: Step 1 targets parasites, larvae, and eggs with wormwood, clove, and neem — Step 2 rebuilds your gut with fulvic acid trace minerals.</p>"
    },
    {
      "type": "header",
      "content": "Urgency & options"
    },
    {
      "type": "checkbox",
      "id": "show_stock_bar",
      "label": "Show stock bar",
      "default": true
    },
    {
      "type": "range",
      "id": "stock_percent",
      "label": "Percent sold",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 93
    },
    {
      "type": "checkbox",
      "id": "show_purchase_options",
      "label": "Show subscription / one-time options",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to cart label",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee line",
      "default": "Backed by our 30-day money-back guarantee — no questions asked."
    },
    {
      "type": "header",
      "content": "Colors & padding"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#22311f"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#3f7d4f"
    },
    {
      "type": "color",
      "id": "sale_color",
      "label": "Sale / urgency color",
      "default": "#b4452e"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✅" },
        { "type": "text", "id": "label", "label": "Label", "default": "Badge" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GC Product Hero",
      "blocks": [
        { "type": "trust", "settings": { "icon": "🚚", "label": "Fast Free Shipping" } },
        { "type": "trust", "settings": { "icon": "🔒", "label": "Secure Checkout" } },
        { "type": "trust", "settings": { "icon": "🌱", "label": "Non-GMO & Vegan" } },
        { "type": "trust", "settings": { "icon": "↩️", "label": "30-Day Returns" } }
      ]
    }
  ]
}
{% endschema %}
