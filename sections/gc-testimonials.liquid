<div
  class="gc-section gc-reviews"
  style="
    --gc-bg: {{ section.settings.background_color }};
    --gc-text: {{ section.settings.text_color }};
    --gc-accent: {{ section.settings.accent_color }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="gc-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="gc-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="gc-reviews__grid">
      {%- for block in section.blocks -%}
        <figure class="gc-review" {{ block.shopify_attributes }}>
          <div class="gc-review__stars" aria-hidden="true">★★★★★</div>
          <blockquote class="gc-review__body">{{ block.settings.body }}</blockquote>
          <figcaption class="gc-review__author">
            <strong>{{ block.settings.name }}</strong>{% if block.settings.meta != blank %}<span>{{ block.settings.meta }}</span>{% endif %}
            {%- if block.settings.verified -%}
              <span class="gc-review__verified">✓ Verified Buyer</span>
            {%- endif -%}
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .gc-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .gc-review {
    margin: 0;
    padding: 28px;
    border-radius: 16px;
    background: color-mix(in srgb, var(--gc-accent) 14%, transparent);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .gc-review__stars {
    color: #f5a623;
    letter-spacing: 2px;
  }
  .gc-review__body {
    margin: 0;
    line-height: 1.6;
    font-size: 1rem;
  }
  .gc-review__author {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.9rem;
  }
  .gc-review__author span {
    opacity: 0.7;
  }
  .gc-review__verified {
    color: var(--gc-accent);
    font-weight: 600;
    opacity: 1 !important;
  }
  @media screen and (max-width: 990px) {
    .gc-reviews__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media screen and (max-width: 749px) {
    .gc-reviews__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "GC Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
