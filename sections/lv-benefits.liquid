<div
  class="lv-section lv-benefits"
  style="
    --lv-bg: {{ section.settings.background_color }};
    --lv-text: {{ section.settings.text_color }};
    --lv-accent: {{ section.settings.accent_color }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="lv-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="lv-benefits__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="lv-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="lv-benefit" {{ block.shopify_attributes }}>
          <div class="lv-benefit__icon">{{ block.settings.icon }}</div>
          <h3 class="lv-benefit__title">{{ block.settings.title }}</h3>
          <p class="lv-benefit__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .lv-benefits__heading {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    margin: 0 0 44px;
  }
  .lv-benefits__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .lv-benefit { text-align: center; }
  .lv-benefit__icon {
    font-size: 2.6rem;
    line-height: 1;
    margin-bottom: 16px;
    color: var(--lv-accent);
  }
  .lv-benefit__title {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0 0 10px;
  }
  .lv-benefit__text { margin: 0; font-size: 0.95rem; line-height: 1.55; opacity: 0.78; }
  @media screen and (max-width: 989px) {
    .lv-benefits__grid { grid-template-columns: 1fr 1fr; gap: 32px 24px; }
  }
  @media screen and (max-width: 600px) {
    .lv-benefits__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LV Benefits Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Choose Lumvelle" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#1a1d18" },
    { "type": "color", "id": "accent_color", "label": "Icon color", "default": "#1c3326" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Top", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🌿" },
        { "type": "text", "id": "title", "label": "Title", "default": "Benefit" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Describe the benefit." }
      ]
    }
  ],
  "presets": [
    {
      "name": "LV Benefits Grid",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "🫀", "title": "Support Digestive Balance", "text": "Promote a calmer, lighter, more comfortable gut." } },
        { "type": "benefit", "settings": { "icon": "🛡️", "title": "Reduce Bloating & Sluggishness", "text": "Help ease that heavy, drained feeling after meals." } },
        { "type": "benefit", "settings": { "icon": "🧠", "title": "Enhance Mental Clarity", "text": "Support clearer thinking by restoring gut harmony." } },
        { "type": "benefit", "settings": { "icon": "⚡", "title": "Promote Daily Vitality", "text": "Feel more energized, focused, and refreshed throughout the day." } }
      ]
    }
  ]
}
{% endschema %}
